{
  "name": "banger",
  "version": "0.1.0",
  "description": "Shell-first, TypeScript-enhanced API testing system",
  "type": "module",
  "bin": {
    "banger": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node scripts/postbuild.mjs",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "lint:yaml": "tsx src/index.ts lint",
    "test:smoke": "tsx src/index.ts run --suite smoke",
    "test:local": "tsx src/index.ts run --env local",
    "test:qa": "tsx src/index.ts run --env QA",
    "test:qa2": "tsx src/index.ts run --env QA-2",
    "pkg:macos": "pkg dist/index.js --target node20-macos-arm64 --output bin/banger-macos-arm64",
    "pkg:linux": "pkg dist/index.js --target node20-linux-x64 --output bin/banger-linux-x64",
    "pkg:all": "npm run build && npm run pkg:macos && npm run pkg:linux"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "pkg": "^5.8.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["api", "testing", "cli", "curl", "http", "yaml"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/banger.git"
  }
}
